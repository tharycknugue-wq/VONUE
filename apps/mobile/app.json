{
  "expo": {
    "name": "Vonue",
    "slug": "vonue",
    "scheme": "vonue",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#E3EAF3",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vonue"
    },
    "android": {
      "package": "app.vonue"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
