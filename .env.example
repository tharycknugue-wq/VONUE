# ==================== App ====================
NODE_ENV=development
PORT=3000
APP_SECRET=change_me_app_secret

# ==================== Database ====================
# Para Docker Compose use o host "localhost" a partir da máquina,
# ou "postgres" quando a API roda dentro de container.
DATABASE_URL=postgresql://vonue:vonue123@localhost:5432/vonue

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379

# ==================== JWT ====================
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ==================== AWS ====================
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vonue-media

# ==================== Pagamentos ====================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAGAR_ME_API_KEY=

# ==================== Push Notifications ====================
FCM_SERVER_KEY=

# ==================== SMS ====================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== Mapbox ====================
MAPBOX_ACCESS_TOKEN=

# ==================== CPF Validation ====================
RECEITA_FEDERAL_API_KEY=

# ==================== Mobile (Expo) ====================
# URL da API acessível pelo dispositivo/emulador.
# Emulador Android: http://10.0.2.2:3000  | Dispositivo físico: http://<IP-DA-MAQUINA>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
